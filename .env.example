# PostgreSQL (общая БД для n8n + схема assistant из postgres/init)
POSTGRES_USER=n8n
POSTGRES_PASSWORD=change_me_strong
POSTGRES_DB=n8n

# n8n: обязательно сгенерировать: openssl rand -hex 32
N8N_ENCRYPTION_KEY=

# Доступ к UI n8n (для reverse-proxy укажите свой домен)
N8N_HOST=0.0.0.0
N8N_PORT=5678
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678/

# Часовой пояс
GENERIC_TIMEZONE=Europe/Moscow
TZ=Europe/Moscow

# Telegram Bot API — в n8n: Credentials → Telegram API (Bot Token от @BotFather)
# TELEGRAM_BOT_TOKEN=  (опционально дублирование здесь для скриптов)

# LLM — в n8n: OpenAI / OpenRouter / локальный Ollama (HTTP Request)
# OPENAI_API_KEY=

# Яндекс.Календарь — OAuth в Yandex ID, затем в n8n HTTP Request или community node
# YANDEX_OAUTH_TOKEN=
